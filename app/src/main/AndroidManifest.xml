<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="b.my.audioplayer">

    <!-- Storage permissions -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29"
        tools:ignore="ScopedStorage" />

    <!-- Service & playback -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Media button / lock screen (needed on some OEMs) -->
    <uses-permission android:name="android.permission.MEDIA_CONTENT_CONTROL"
        tools:ignore="ProtectedPermission" />

    <!-- Bluetooth -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Misc -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <application
        android:name=".BPlayerApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BPlayer"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- ==================== Activities ==================== -->

        <activity
            android:name=".activity.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.BPlayer">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activity.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustNothing">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/*" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activity.NowPlayingActivity"
            android:exported="false"
            android:theme="@style/Theme.BPlayer" />

        <activity android:name=".activity.PlaylistActivity"       android:exported="false" />
        <activity android:name=".activity.PlaylistDetailActivity" android:exported="false" />
        <activity android:name=".activity.EqualizerActivity"      android:exported="false" />
        <activity android:name=".activity.SearchActivity"         android:exported="false"
            android:windowSoftInputMode="stateVisible" />
        <activity android:name=".activity.SettingsActivity"       android:exported="false" />
        <activity android:name=".activity.TagEditorActivity"      android:exported="false" />
        <activity android:name=".activity.AlbumDetailActivity"    android:exported="false" />
        <activity android:name=".activity.ArtistDetailActivity"   android:exported="false" />
        <activity android:name=".activity.SongPickerActivity"     android:exported="false" />
        <activity android:name=".activity.LyricsActivity"         android:exported="false" />

        <!-- ==================== Foreground Service ==================== -->

        <!--
            foregroundServiceType="mediaPlayback" is required on Android 10+ (API 29+)
            for a foreground service that plays audio.
            On Android 14+ (API 34) this must be declared or the service will crash.
        -->
        <service
            android:name=".service.MusicPlaybackService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback">

            <!--
                FLAG_HANDLES_MEDIA_BUTTONS in MediaSession means the system routes
                hardware-button intents here.  The intent-filter below is still
                needed on some OEM ROMs (Samsung, MIUI, etc.).
            -->
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </service>

        <!-- ==================== Widgets ==================== -->

        <receiver
            android:name=".widget.MusicWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="b.my.audioplayer.widget.PLAY_PAUSE" />
                <action android:name="b.my.audioplayer.widget.NEXT" />
                <action android:name="b.my.audioplayer.widget.PREVIOUS" />
                <action android:name="b.my.audioplayer.widget.UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/music_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.MusicWidgetProviderLarge"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="b.my.audioplayer.widget.PLAY_PAUSE_LARGE" />
                <action android:name="b.my.audioplayer.widget.NEXT_LARGE" />
                <action android:name="b.my.audioplayer.widget.PREVIOUS_LARGE" />
                <action android:name="b.my.audioplayer.widget.UPDATE_LARGE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/music_widget_large_info" />
        </receiver>

        <!-- ==================== Receivers ==================== -->

        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!--
            NotificationReceiver is no longer used for notification button actions —
            those now go directly to MusicPlaybackService via PendingIntent.getService().
            Keeping the receiver here in case other parts of the app still send broadcasts.
            exported="false" is correct — only our own app sends these.
        -->
        <receiver
            android:name=".receiver.NotificationReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="b.my.audioplayer.ACTION_PLAY" />
                <action android:name="b.my.audioplayer.ACTION_PAUSE" />
                <action android:name="b.my.audioplayer.ACTION_NEXT" />
                <action android:name="b.my.audioplayer.ACTION_PREVIOUS" />
                <action android:name="b.my.audioplayer.ACTION_STOP" />
                <action android:name="b.my.audioplayer.ACTION_TOGGLE_PLAYBACK" />
            </intent-filter>
        </receiver>

        <!-- ==================== FileProvider ==================== -->

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="b.my.audioplayer.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths" />
        </provider>

    </application>

</manifest>