        <!-- Playback Section -->
        <b.my.audioplayer.utils.GradientTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Playback"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/colorSecondary"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:alpha="0.8"/>

        <!-- Crossfade -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_crossfade" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <b.my.audioplayer.utils.GradientTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Crossfade"
                    android:textSize="16sp"
                    android:textColor="@color/colorSecondary"/>

                <b.my.audioplayer.utils.GradientTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Smooth transition between songs"
                    android:textSize="14sp"
                    android:textColor="@color/colorSecondary"
                    android:alpha="0.6"/>

            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchCrossfade"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@android:color/darker_gray"
                app:trackTint="@color/colorSecondary"/>

        </LinearLayout>

        <!-- Crossfade Duration -->
        <LinearLayout
            android:id="@+id/layoutCrossfadeDuration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp"
            android:visibility="gone">

            <b.my.audioplayer.utils.GradientTextView
                android:id="@+id/textCrossfadeDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Duration: 3 seconds"
                android:textSize="14sp"
                android:textColor="@color/colorSecondary"
                android:alpha="0.6"/>

            <SeekBar
                android:id="@+id/seekBarCrossfade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="10"
                android:progress="3"
                android:progressTint="@color/colorSecondary"
                android:thumbTint="@color/colorSecondary"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorSecondary"
            android:alpha="0.2"
            android:layout_marginHorizontal="16dp"/>

        <!-- Audio Section -->
        <b.my.audioplayer.utils.GradientTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Audio"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:alpha="0.8"/>

        <!-- Volume Normalization -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_volume"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <b.my.audioplayer.utils.GradientTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Volume Normalization"
                    android:textSize="16sp"/>

                <b.my.audioplayer.utils.GradientTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Normalize playback volume"
                    android:textSize="14sp"
                    android:alpha="0.6"/>

            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchVolumeNormalization"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@android:color/darker_gray"
                app:trackTint="@color/colorSecondary"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorSecondary"
            android:alpha="0.2"
            android:layout_marginHorizontal="16dp"/>

        <!-- Library Section -->
        <b.my.audioplayer.utils.GradientTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Library"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:alpha="0.8"/>

        <!-- Scan Media -->
        <LinearLayout
            android:id="@+id/btnScanMedia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_refresh"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <b.my.audioplayer.utils.GradientTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Scan Media"
                    android:textSize="16sp"/>

                <b.my.audioplayer.utils.GradientTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Rescan device for audio files"
                    android:textSize="14sp"
                    android:alpha="0.6"/>

            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorSecondary"
            android:alpha="0.2"
            android:layout_marginHorizontal="16dp"/>

        <!-- About Section -->
        <b.my.audioplayer.utils.GradientTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="About"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:alpha="0.8"/>

        <!-- App Version -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_info"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <b.my.audioplayer.utils.GradientTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Version"
                    android:textSize="16sp"/>

                <b.my.audioplayer.utils.GradientTextView
                    android:id="@+id/textAppVersion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1.0.0"
                    android:textSize="14sp"
                    android:alpha="0.6"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>